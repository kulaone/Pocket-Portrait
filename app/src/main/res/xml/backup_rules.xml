<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude EncryptedSharedPreferences since the hardware master key is device-bound -->
        <exclude domain="sharedpref" path="secure_settings.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_settings.xml" />
    </device-transfer>
</data-extraction-rules>